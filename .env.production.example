# ============================================
# APEXAFRIKA - Production Environment Variables
# ============================================

# Django
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_ENV=production
DEBUG=False
ALLOWED_HOSTS=apexafrika.com,www.apexafrika.com,api.apexafrika.com

# Database
DB_NAME=apexafrika_prod_db
DB_USER=apexafrika_prod_user
DB_PASSWORD=your-production-db-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-production-redis-password

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Google OAuth
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_SECRET_KEY=your-production-google-secret

# Email
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@apexafrika.com
FRONTEND_URL=https://apexafrika.com

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_MERCHANT_EMAIL=merchant@apexafrika.com
PAYSTACK_ENVIRONMENT=live

# GROQ AI
GROQ_API_KEY=your-production-groq-key
GROQ_MODEL=llama3-70b-8192

# Django Superuser (optional)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@apexafrika.com
DJANGO_SUPERUSER_PASSWORD=your-strong-admin-password

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# Security
CSRF_TRUSTED_ORIGINS=https://apexafrika.com,https://www.apexafrika.com
CORS_ALLOWED_ORIGINS=https://apexafrika.com,https://www.apexafrika.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
