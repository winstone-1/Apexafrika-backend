{
  "info": {
    "name": "ApexAfrika API - Complete (19 Apps)",
    "description": "ApexAfrika - Game Operations Platform for African Esports\n\nComplete API collection with all 19 apps:\n- Authentication (JWT)\n- Tournament Management\n- Player Analytics\n- Community\n- Payments (M-Pesa)\n- Notifications\n- Chat (WebSocket-ready)\n- AI (Groq)\n- Teams\n- Sponsors\n- Achievements\n- Schedules\n- Streaming\n- Content & Education\n- Newsletter\n- Feedback\n- Audit\n- Legal\n\nSet base_url = http://127.0.0.1:8000\nAfter login, paste access token into the access_token variable.\n\nFor admin endpoints, use admin credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:8000", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "refresh_token", "value": "", "type": "string"},
    {"key": "tournament_id", "value": "1", "type": "string"},
    {"key": "match_id", "value": "1", "type": "string"},
    {"key": "team_id", "value": "1", "type": "string"},
    {"key": "post_id", "value": "1", "type": "string"},
    {"key": "article_id", "value": "1", "type": "string"},
    {"key": "stream_id", "value": "1", "type": "string"},
    {"key": "user_id", "value": "1", "type": "string"},
    {"key": "feedback_id", "value": "1", "type": "string"},
    {"key": "subscription_id", "value": "1", "type": "string"}
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Player",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"testplayer\",\n  \"email\": \"test@apexafrika.com\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"gamer_tag\": \"NoobSlayerKE\",\n  \"role\": \"PLAYER\"\n}"}
          }
        },
        {
          "name": "Register Organizer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"tournamentorg\",\n  \"email\": \"org@apexafrika.com\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"gamer_tag\": \"TournamentPro\",\n  \"role\": \"ORGANIZER\"\n}"}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"testplayer\",\n  \"password\": \"TestPass123!\"\n}"}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"access_token\", jsonData.access);",
                  "    pm.environment.set(\"refresh_token\", jsonData.refresh);",
                  "    pm.environment.set(\"user_id\", jsonData.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"}
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/profile/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]}
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/auth/profile/",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"bio\": \"Professional Valorant player from Kenya\",\n  \"phone_number\": \"+254712345678\",\n  \"main_game\": \"Valorant\",\n  \"twitter\": \"@apexgamer\",\n  \"twitch\": \"twitch.tv/apexgamer\"\n}"}
          }
        }
      ]
    },
    {
