        {
          "name": "Filter Tournaments - By Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tournaments/?status=REGISTRATION",
            "header": []}
        },
        {
          "name": "Filter Tournaments - By Game",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tournaments/?game=Valorant",
            "header": []}
        },
        {
          "name": "Create Tournament",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/tournaments/",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Safi Series Valorant Tournament\",\n  \"description\": \"First-ever Safi Series Valorant tournament in Kenya!\",\n  \"game\": \"Valorant\",\n  \"format\": \"SINGLE_ELIM\",\n  \"status\": \"REGISTRATION\",\n  \"registration_start\": \"2026-07-20T00:00:00Z\",\n  \"registration_end\": \"2026-07-27T23:59:59Z\",\n  \"start_date\": \"2026-07-30T09:00:00Z\",\n  \"max_players\": 16,\n  \"min_players\": 4,\n  \"prize_pool\": 5000,\n  \"currency\": \"KES\",\n  \"prize_distribution\": [{\"rank\": 1, \"amount\": 3000}, {\"rank\": 2, \"amount\": 1500}, {\"rank\": 3, \"amount\": 500}],\n  \"is_public\": true,\n  \"is_featured\": true,\n  \"rules\": \"Standard competitive rules apply. Best of 3 for finals.\"\n}"}
          }
        },
        {
          "name": "Get Tournament Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/",
            "header": []}
        },
        {
          "name": "Update Tournament",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"prize_pool\": 10000,\n  \"max_players\": 32\n}"}
          }
        },
        {
          "name": "Delete Tournament",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]}
        },
        {
          "name": "Register for Tournament",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/register/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]}
        },
        {
          "name": "Get Tournament Participants",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/participants/",
            "header": []}
        },
        {
          "name": "Start Tournament (Generate Brackets)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/start/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]}
        },
        {
          "name": "Get Tournament Brackets",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tournaments/{{tournament_id}}/brackets/",
            "header": []}
        }
      ]
    },
